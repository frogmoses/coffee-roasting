# find-coffee companion app URL (for bean profile lookups)
FIND_COFFEE_URL=http://localhost:5000

# Path to the find-coffee wrapper script (auto-starts server if not running)
FIND_COFFEE_WRAPPER=/path/to/run_find-coffee

# Sentinel capture directories (colon-separated, scanned for sentinel_*.json)
# SENTINEL_CAPTURES_DIRS=/path/to/r1-eye/captures:/path/to/gopro/captures
